# .env.example — 复制为 .env 并填入实际值

# 应用配置
APP_NAME=BillAgent
DEBUG=true
API_V1_PREFIX=/api/v1

# 数据库连接（PostgreSQL 推荐，也支持 SQLite）
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/bill_db

# LLM 配置（支持 OpenAI / 智谱 / DeepSeek / Ollama 等兼容服务）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 多模态模型（用于 OCR 图片识别，需支持 vision）
VISION_MODEL=glm-4v

# 角色预设（可选: buddy / cat / analyst / homie / custom）
PERSONA=buddy
PERSONA_CUSTOM=

# 会话保留：超过此天数自动压缩上下文（保留 system prompt + 最近 N 轮）
CHAT_SESSION_TTL_DAYS=7
CHAT_KEEP_RECENT_ROUNDS=5
